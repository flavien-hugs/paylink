# BACKEND CONFIG
APP_NAME="PayLink API"
APP_VERSION=1.0.0
API_PREFIX=/api
HIDE_DOCS=false

# CORS CONFIG — accepts a JSON array OR a comma-separated string via CORS_ORIGINS.
CORS_ORIGINS="http://localhost:5173,http://localhost:4173"

# POSTGRES CONFIG
POSTGRES_DB=change-me-in-production
POSTGRES_USER=change-me-in-production
POSTGRES_PASSWORD=change-me-in-production
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# API SECURITY
JWT_SECRET=change-me-in-production
FERNET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=720

# FRONTEND CONFIG
ADMIN_ORIGIN=http://localhost:4173
PAYMENT_WEB_URL=http://localhost:5173
PUBLIC_API_URL=http://localhost:8000/api

# BOOTSTRAP SEED (created on first start when SEED_ON_START=true)
SEED_ON_START=true
SEED_ADMIN_EMAIL=change-me-in-production
SEED_ADMIN_PASSWORD=change-me-in-production
SEED_ENTITY_SLUG=change-me-in-production
SEED_ENTITY_NAME=change-me-in-production
SEED_KKIAPAY_PUBLIC_KEY=your-sandbox-public-key
SEED_KKIAPAY_PRIVATE_KEY=your-sandbox-private-key
SEED_KKIAPAY_SECRET=your-sandbox-secret

# KKIAPAY (sandbox by default)
KKIAPAY_API_URL=https://api.kkiapay.me
KKIAPAY_SANDBOX_API_URL=https://api-sandbox.kkiapay.me
